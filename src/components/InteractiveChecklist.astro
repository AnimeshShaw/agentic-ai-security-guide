---
export interface ChecklistGroup {
  title: string;
  items: string[];
}

export interface Props {
  groups: ChecklistGroup[];
  /** Storage key for localStorage persistence. Must be a safe identifier [a-zA-Z0-9_-]. */
  storageKey?: string;
}

const { groups, storageKey: rawKey = 'ai-security-checklist' } = Astro.props;

// Validate storageKey — only allow safe identifier characters to prevent
// any edge-case injection if the key were ever passed dynamically.
const storageKey = /^[a-zA-Z0-9_-]+$/.test(rawKey) ? rawKey : 'ai-security-checklist';

const total = groups.reduce((sum, g) => sum + g.items.length, 0);
// Use crypto.randomUUID for a collision-resistant, non-predictable DOM ID.
const id = `checklist-${crypto.randomUUID().replace(/-/g, '').slice(0, 8)}`;

function makeId(gi: number, ii: number) {
  return `item-${gi}-${ii}`;
}
---

<div class="checklist-wrapper" id={id}>
  <div class="checklist-progress-bar">
    <div class="checklist-progress-fill" style="width: 0%"></div>
  </div>
  <p class="checklist-progress-label"><span class="done-count">0</span> of {total} completed</p>

  {groups.map((group, gi) => (
    <div class="checklist-group">
      <div class="checklist-group-title">{group.title}</div>
      {group.items.map((item, ii) => (
        <label class="checklist-item" data-item-id={makeId(gi, ii)}>
          <input type="checkbox" data-id={makeId(gi, ii)} />
          <span class="checklist-item-text">{item}</span>
        </label>
      ))}
    </div>
  ))}
</div>

<script define:vars={{ id, storageKey, total }}>
  const wrap = document.getElementById(id);
  if (!wrap) return;

  const fill  = wrap.querySelector('.checklist-progress-fill');
  const count = wrap.querySelector('.done-count');
  const boxes = wrap.querySelectorAll('input[type="checkbox"]');

  function load() {
    let saved = {};
    try {
      const raw = localStorage.getItem(storageKey);
      const parsed = JSON.parse(raw || '{}');
      // Ensure we got a plain object, not an array or primitive.
      if (parsed && typeof parsed === 'object' && !Array.isArray(parsed)) {
        saved = parsed;
      }
    } catch (_) {
      // Corrupted storage — start fresh.
    }
    boxes.forEach((box) => {
      const checked = saved[box.dataset.id] === true;
      box.checked = checked;
      box.closest('.checklist-item')?.classList.toggle('checked', checked);
    });
    update();
  }

  function update() {
    const done = Array.from(boxes).filter((b) => b.checked).length;
    const pct  = total > 0 ? (done / total) * 100 : 0;
    if (fill)  fill.style.width = pct + '%';
    if (count) count.textContent = String(done);
  }

  function save() {
    try {
      const data = {};
      boxes.forEach((b) => { data[b.dataset.id] = b.checked; });
      localStorage.setItem(storageKey, JSON.stringify(data));
    } catch (_) {
      // localStorage may be unavailable (private browsing, quota exceeded).
    }
  }

  boxes.forEach((box) => {
    box.addEventListener('change', () => {
      box.closest('.checklist-item')?.classList.toggle('checked', box.checked);
      save();
      update();
    });
  });

  load();
</script>
